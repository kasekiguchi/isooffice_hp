---
const base = import.meta.env.BASE_URL;
const { topics = [] } = Astro.props;

// body 内の相対リンクにベースパスを付与し、旧 .html パスをディレクトリURLへ変換。
function rewriteBody(html) {
  return html.replace(/href="(?!https?:|mailto:|#|\/)([^"]*)"/g, (_m, p) => {
    p = p.replace(/index\.html$/, '').replace(/\.html$/, '/');
    return `href="${base}${p}"`;
  });
}
---
<div class="topics">
  {topics.map((t) => (
    <article class="topic" id={t.id}>
      {t.date && <span class="topic__date">{t.date}</span>}
      <h3 class="topic__title">{t.title}</h3>
      {t.body && <div class="topic__body" set:html={rewriteBody(t.body)} />}
      {t.images && t.images.length > 0 && (
        <div class="topic__images">
          {t.images.map((img) => (
            <a href={base + img.src} target="_blank" rel="noopener">
              <img src={base + img.src} alt={img.alt} loading="lazy" />
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
