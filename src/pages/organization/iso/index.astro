---
import Base from '../../../layouts/Base.astro';
import SubNav from '../../../components/SubNav.astro';
const base = import.meta.env.BASE_URL;
const items = [
  { href: 'organization/', label: '組織体系', key: 'index' },
  { href: 'organization/iso/', label: 'ISO組織体制', key: 'iso' },
  { href: 'organization/committee/', label: '環境委員会', key: 'committee' },
  { href: 'organization/aspect/', label: '環境側面', key: 'aspect' },
];
---
<Base title="ISO組織体制" current="organization" description="2025年度 ISO組織体制。">
  <main>
    <div class="container prose">
      <h1 class="page-title">2025年度 ISO組織体制</h1>
      <SubNav items={items} active="iso" />
      <p class="figure-note">↓ クリックすると拡大します</p>
      <a class="figure-zoom" href={base + 'organization/img/体制2025.png'} target="_blank" rel="noopener">
        <img src={base + 'organization/img/体制2025.png'} alt="2025年度 ISO組織体制" loading="lazy" />
      </a>
    </div>
  </main>
</Base>
