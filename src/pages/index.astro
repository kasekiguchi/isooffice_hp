---
import Base from '../layouts/Base.astro';
import TopicArticle from '../components/TopicArticle.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL;

// 最新のお知らせ（archive でないもの）を日付降順で。
const entries = (await getCollection('topics', ({ data }) => !data.archive)).sort(
  (a, b) => b.data.date.localeCompare(a.data.date),
);
const rendered = await Promise.all(
  entries.map(async (e) => ({ entry: e, Content: (await render(e)).Content })),
);
---
<Base current="home">
  <section class="hero">
    <div class="container">
      <h1>東京都市大学 横浜キャンパス<br />ISO事務局</h1>
      <p>
        当サイトは東京都市大学 横浜キャンパス ISO事務局のサイトです。ISO14001の環境管理における
        PDCAサイクルの活動や取組みに関する様々な情報を発信しています。横浜キャンパスやISO活動、
        その他 東京都市大学に関するお問い合わせは
        <a href="https://www.tcu.ac.jp/contact/index.html" style="color:#fff;text-decoration:underline;">こちら</a>
        からお願いします。
      </p>
    </div>
  </section>

  <main>
    <div class="container">
      <h2 class="page-title">お知らせ・トピックス</h2>
      <div class="topics">
        {rendered.map(({ entry, Content }) => (
          <TopicArticle id={entry.id} data={entry.data}>
            <Content />
          </TopicArticle>
        ))}
      </div>
      <p style="margin-top:2em;text-align:right;">
        <a class="btn btn--outline" href={base + 'topics/'}>過去のトピックス ≫</a>
      </p>
    </div>
  </main>
</Base>
