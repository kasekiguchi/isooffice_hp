---
import Base from '../layouts/Base.astro';
import { topics } from '../data/topics.js';

const base = import.meta.env.BASE_URL; // 末尾 "/" 付き

// body 内の相対リンク (href="record/..." 等) にベースパスを付与する。
// 旧サイトの .html パスは新しいディレクトリURL（末尾スラッシュ）へ変換する。
// 外部URL・mailto・アンカーはそのまま。
function rewriteBody(html) {
  return html.replace(/href="(?!https?:|mailto:|#|\/)([^"]*)"/g, (_m, p) => {
    p = p.replace(/index\.html$/, '').replace(/\.html$/, '/');
    return `href="${base}${p}"`;
  });
}
---
<Base current="home">
  <section class="hero">
    <div class="container">
      <h1>東京都市大学 横浜キャンパス<br />ISO事務局</h1>
      <p>
        当サイトは東京都市大学 横浜キャンパス ISO事務局のサイトです。ISO14001の環境管理における
        PDCAサイクルの活動や取組みに関する様々な情報を発信しています。横浜キャンパスやISO活動、
        その他 東京都市大学に関するお問い合わせは
        <a href="https://www.tcu.ac.jp/contact/index.html" style="color:#fff;text-decoration:underline;">こちら</a>
        からお願いします。
      </p>
    </div>
  </section>

  <main>
    <div class="container">
      <h2 class="page-title">お知らせ・トピックス</h2>
      <div class="topics">
        {topics.map((t) => (
          <article class="topic" id={t.id}>
            <span class="topic__date">{t.date}</span>
            <h3 class="topic__title">{t.title}</h3>
            <div class="topic__body" set:html={rewriteBody(t.body)} />
            {t.images.length > 0 && (
              <div class="topic__images">
                {t.images.map((img) => (
                  <a href={base + img.src} target="_blank" rel="noopener">
                    <img src={base + img.src} alt={img.alt} loading="lazy" />
                  </a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </main>
</Base>
